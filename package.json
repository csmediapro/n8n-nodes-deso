{
  "name": "n8n-nodes-deso",
  "version": "1.0.6",
  "description": "n8n community node for DeSo Identity authentication, image posting, and profile lookup",
  "keywords": [
    "n8n-community-node-package",
    "deso",
    "deso-identity",
    "deso-protocol",
    "blockchain",
    "decentralized-social",
    "automation",
    "social-media"
  ],
  "license": "MIT",
  "author": {
    "name": "CSMediaPro",
    "email": "contact@csmediapro.com",
    "url": "https://csmediapro.com"
  },
  "homepage": "https://csmediapro.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csmediapro/n8n-nodes-deso.git"
  },
  "bugs": {
    "url": "https://github.com/csmediapro/n8n-nodes-deso/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "auth",
    "logo.svg"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DesoIdentityApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Deso/Deso.node.js"
    ]
  },
  "scripts": {
    "build": "npm run bundle-deso-protocol:src && n8n-node build && npm run bundle-deso-protocol:dist",
    "bundle-auth": "esbuild node_modules/deso-protocol/src/index.js --bundle --format=iife --global-name=deso --platform=browser --outfile=auth/deso-protocol.bundle.js",
    "bundle-deso-protocol:src": "esbuild node_modules/deso-protocol/src/index.js --bundle --platform=node --format=cjs --target=node20 --outfile=src/vendor/deso-protocol.cjs",
    "bundle-deso-protocol:dist": "esbuild node_modules/deso-protocol/src/index.js --bundle --platform=node --format=cjs --target=node20 --outfile=dist/src/vendor/deso-protocol.cjs",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "prelint": "npm run bundle-deso-protocol:src",
    "test:profile": "npm run build && node scripts/test-operations.js",
    "test:post": "npm run build && node scripts/test-operations.js --post",
    "test:image-post": "npm run build && node scripts/test-operations.js --post --image",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.33.1",
    "@types/node": "^22.5.5",
    "deso-protocol": "^3.3.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.29.0",
    "n8n-core": "^1.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
