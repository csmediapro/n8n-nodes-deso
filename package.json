{
  "name": "n8n-nodes-deso",
  "version": "1.0.7",
  "description": "n8n community node for DeSo Identity authentication, image posting, and profile lookup",
  "keywords": [
    "n8n-community-node-package",
    "deso",
    "deso-identity",
    "blockchain",
    "decentralized-social",
    "automation",
    "social-media"
  ],
  "license": "MIT",
  "author": {
    "name": "CSMediaPro",
    "email": "contact@csmediapro.com",
    "url": "https://csmediapro.com"
  },
  "homepage": "https://csmediapro.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csmediapro/n8n-nodes-deso.git"
  },
  "bugs": {
    "url": "https://github.com/csmediapro/n8n-nodes-deso/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "logo.svg"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DesoIdentityApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Deso/Deso.node.js"
    ]
  },
  "scripts": {
    "build": "npm run bundle-deso-signing:src && n8n-node build && npm run bundle-deso-signing:dist",
    "bundle-deso-signing:src": "esbuild tools/desoSigningBundle.ts --bundle --platform=node --format=cjs --target=node20 --outfile=src/vendor/deso-signing.cjs",
    "bundle-deso-signing:dist": "esbuild tools/desoSigningBundle.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/src/vendor/deso-signing.cjs",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test:profile": "npm run build && node scripts/test-operations.js",
    "test:post": "npm run build && node scripts/test-operations.js --post",
    "test:image-post": "npm run build && node scripts/test-operations.js --post --image",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.33.1",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^1.7.2",
    "@types/node": "^22.5.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.29.0",
    "n8n-core": "^1.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
